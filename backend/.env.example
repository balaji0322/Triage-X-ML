# ============================================
# TRIAGE-X ENVIRONMENT CONFIGURATION
# ============================================

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017/
DB_NAME=triage_system

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token Expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/triage-x.log

# Model Paths (relative to backend directory)
MODEL_PATH=models/triage_model.pkl
LABEL_MAP_PATH=models/label_map.pkl
FEATURE_IMPORTANCE_PATH=models/feature_importance.pkl
